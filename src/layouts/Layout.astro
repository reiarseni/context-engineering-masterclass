---
// Layout base de Astro — aquí definimos el HTML shell
// En Astro, los componentes .astro corren en el servidor (o build time)
// Solo los componentes React con client:* directivas son interactivos

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Masterclass interactiva sobre Context Engineering y Agentic Systems" />
    <title>{title}</title>
    <!-- Las fuentes se cargan desde el CSS inyectado por el componente React -->
  </head>
  <body>
    <!-- slot es donde Astro inyecta el contenido hijo -->
    <slot />
  </body>
</html>

<style is:global>
  /* Reset mínimo — el resto lo maneja el CSS-in-JS del componente React */
  html, body {
    margin: 0;
    padding: 0;
    background: #070b14;
  }
</style>
